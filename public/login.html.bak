<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OpenVPN & WireGuard Manager — Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- AOS (Animate On Scroll) -->
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        background: '#09090b',
                        surface: '#121214',
                        border: '#27272a',
                        primary: '#00f0ff',
                        danger: '#ef4444',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'UI monospace', 'monospace']
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #09090b;
            color: #ffffff;
            background-image:
                linear-gradient(rgba(39,39,42,0.5) 1px, transparent 1px),
                linear-gradient(90deg, rgba(39,39,42,0.5) 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .sci-fi-card {
            background-color: #121214;
            border: 1px solid #27272a;
            border-radius: 0.5rem;
            position: relative;
            overflow: hidden;
        }
        .sci-fi-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 2px;
            background: linear-gradient(90deg, transparent, #00f0ff, transparent);
            opacity: 0.6;
        }

        .sci-fi-input {
            background: rgba(0,0,0,0.4);
            border: 1px solid #27272a;
            color: #e4e4e7;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%;
            padding: 0.6rem 0.875rem;
            border-radius: 0.375rem;
            outline: none;
        }
        .sci-fi-input:focus {
            border-color: #00f0ff;
            box-shadow: 0 0 0 2px rgba(0,240,255,0.15);
        }
        .sci-fi-input::placeholder { color: #52525b; }

        .sci-fi-button-primary {
            background: transparent;
            color: #00f0ff;
            border: 1px solid #00f0ff;
            text-shadow: 0 0 8px rgba(0,240,255,0.5);
            box-shadow: inset 0 0 10px rgba(0,240,255,0.1);
            transition: all 0.2s;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 0.75rem 1.5rem;
            border-radius: 0.375rem;
            width: 100%;
            cursor: pointer;
        }
        .sci-fi-button-primary:hover:not(:disabled) {
            background: rgba(0,240,255,0.1);
            box-shadow: inset 0 0 20px rgba(0,240,255,0.2), 0 0 15px rgba(0,240,255,0.4);
        }
        .sci-fi-button-primary:active:not(:disabled) { transform: scale(0.98); }
        .sci-fi-button-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            filter: grayscale(80%);
        }

        .glitch-wrapper { position: relative; display: inline-block; }
        .glitch-text { color: white; position: relative; z-index: 1; }
        .glitch-text::before {
            content: attr(data-text);
            position: absolute; top: 0; left: 0;
            color: #00f0ff; opacity: 0.7; z-index: -1;
            transform: translate(-2px, 2px);
            animation: glitch-anim 2.5s infinite alternate-reverse;
            pointer-events: none;
        }
        .glitch-text::after {
            content: attr(data-text);
            position: absolute; top: 0; left: 0;
            color: #ff00ea; opacity: 0.45; z-index: -2;
            transform: translate(2px, -2px);
            animation: glitch-anim2 3.1s infinite alternate;
            pointer-events: none;
        }
        /* baris ke-2 (Terminal) — timing berbeda agar tidak sinkron */
        .glitch-text.glitch-line2::before {
            animation: glitch-anim 1.8s 0.6s infinite alternate;
        }
        .glitch-text.glitch-line2::after {
            animation: glitch-anim2 2.4s 1.1s infinite alternate-reverse;
        }
        @keyframes glitch-anim {
            0%   { clip-path: inset(10% 0 10% 0); }
            20%  { clip-path: inset(80% 0  5% 0); }
            40%  { clip-path: inset(20% 0 40% 0); }
            60%  { clip-path: inset(50% 0 30% 0); }
            80%  { clip-path: inset( 5% 0 80% 0); }
            100% { clip-path: inset(30% 0 10% 0); }
        }
        @keyframes glitch-anim2 {
            0%   { clip-path: inset(60% 0 10% 0); }
            25%  { clip-path: inset(10% 0 70% 0); }
            50%  { clip-path: inset(35% 0 35% 0); }
            75%  { clip-path: inset(90% 0  2% 0); }
            100% { clip-path: inset(15% 0 55% 0); }
        }

        /* Scanline animation on the logo */
        @keyframes scan {
            0%   { background-position: 0 -100vh; }
            100% { background-position: 0  100vh; }
        }
        .scan-lines {
            pointer-events: none;
            background: repeating-linear-gradient(
                to bottom,
                transparent 0px,
                transparent 3px,
                rgba(0,240,255,0.03) 3px,
                rgba(0,240,255,0.03) 4px
            );
            animation: scan 6s linear infinite;
        }

        .error-msg {
            color: #fca5a5;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            background: rgba(239,68,68,0.08);
            border-left: 3px solid #ef4444;
            padding: 0.5rem 0.75rem;
            border-radius: 0 0.25rem 0.25rem 0;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-sm">
        <!-- Logo / Title -->
        <div class="text-center mb-10" data-aos="fade-down" data-aos-duration="600">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-lg border border-primary mb-4 relative overflow-hidden"
                 style="background:#0a1a1b; box-shadow: 0 0 25px rgba(0,240,255,0.3);">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div class="scan-lines absolute inset-0"></div>
            </div>
            <h1 class="font-bold tracking-wider uppercase text-center leading-tight">
                <span class="glitch-wrapper"><span class="glitch-text text-xl" data-text="OpenVPN &amp; WireGuard">OpenVPN &amp; WireGuard</span></span><br>
                <span class="glitch-wrapper"><span class="glitch-text glitch-line2 text-2xl" data-text="Terminal">Terminal</span></span>
            </h1>
            <p class="text-gray-500 text-xs tracking-[0.25em] uppercase mt-2">Secure Access Required</p>
        </div>

        <!-- Login Card -->
        <div class="sci-fi-card p-8 shadow-xl" data-aos="fade-up" data-aos-delay="150" data-aos-duration="600">
            <h2 class="text-xs font-mono text-gray-500 uppercase tracking-widest mb-6 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                </svg>
                Authentication
            </h2>

            <!-- Error banner -->
            <div id="errorMsg" class="error-msg mb-5 hidden"></div>

            <form id="loginForm" autocomplete="off" class="space-y-5">
                <div>
                    <label class="block text-xs text-gray-500 font-mono uppercase tracking-widest mb-1.5">Username</label>
                    <input id="username" type="text" placeholder="admin"
                           class="sci-fi-input" autocomplete="username" required />
                </div>
                <div>
                    <label class="block text-xs text-gray-500 font-mono uppercase tracking-widest mb-1.5">Password</label>
                    <div class="relative">
                        <input id="password" type="password" placeholder="••••••••"
                               class="sci-fi-input pr-10" autocomplete="current-password" required />
                        <button type="button" id="togglePass"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-600 hover:text-primary transition-colors focus:outline-none"
                                tabindex="-1" title="Show / hide password">
                            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <button id="btnLogin" type="submit" class="sci-fi-button-primary mt-2">
                    <span id="btnLabel">Authenticate</span>
                </button>
            </form>
        </div>

        <p class="text-center text-gray-700 text-xs font-mono mt-6 tracking-widest" data-aos="fade-up" data-aos-delay="300" data-aos-duration="600">
            OpenVPN & WireGuard Web Manager &nbsp;|&nbsp; v1.0
        </p>
    </div>

    <script>
        const form     = document.getElementById('loginForm');
        const errorMsg = document.getElementById('errorMsg');
        const btnLogin = document.getElementById('btnLogin');
        const btnLabel = document.getElementById('btnLabel');

        // Toggle password visibility
        document.getElementById('togglePass').addEventListener('click', () => {
            const pw = document.getElementById('password');
            pw.type = pw.type === 'password' ? 'text' : 'password';
        });

        // If already authenticated, go straight to dashboard
        (async () => {
            try {
                const r = await fetch('/api/status');
                if (r.ok) window.location.replace('/');
            } catch (_) {}
        })();

        function showError(msg) {
            errorMsg.textContent = '> ' + msg;
            errorMsg.classList.remove('hidden');
        }
        function hideError() {
            errorMsg.classList.add('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError();

            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value;

            if (!username || !password) {
                showError('Username and password are required.');
                return;
            }

            btnLogin.disabled = true;
            btnLabel.textContent = 'Authenticating...';

            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, password })
                });

                if (res.ok) {
                    btnLabel.textContent = 'Access Granted ✓';
                    setTimeout(() => window.location.replace('/'), 400);
                } else {
                    showError('Invalid credentials. Access denied.');
                    btnLogin.disabled = false;
                    btnLabel.textContent = 'Authenticate';
                    document.getElementById('password').value = '';
                    document.getElementById('password').focus();
                }
            } catch (err) {
                showError('Connection error. Server may be unreachable.');
                btnLogin.disabled = false;
                btnLabel.textContent = 'Authenticate';
            }
        });
    </script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>AOS.init({ duration: 600, once: true, easing: 'ease-out-quart' });</script>
</body>
</html>
