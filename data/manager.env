# ============================================================
# OpenVPN Manager — Per-Server Environment Override
# File   : /etc/openvpn/manager.env
# ============================================================
# Nilai di file ini OVERRIDE manager.toon, tapi masih bisa
# di-override lagi oleh environment variable nyata di shell.
#
# Prioritas (tertinggi → terendah):
#   1. Env var nyata di shell / systemd Environment=
#   2. Nilai di file ini (manager.env)
#   3. Nilai di manager.toon
#   4. Built-in default di binary
#
# CARA PAKAI DI SERVER BERBEDA:
#   1. Copy seluruh /opt/openvpn-web-ui ke server baru
#   2. Edit file ini — minimal ubah OVPN_PUBLIC_IP
#   3. Sesuaikan OVPN_SERVICE jika nama unit systemd berbeda
#   4. systemctl restart openvpn-manager
# ============================================================

# ── Identitas Server ────────────────────────────────────────
# IP publik server ini yang akan ditulis ke dalam .ovpn client.
# Kosongkan untuk auto-detect via api.ipify.org saat startup.
OVPN_PUBLIC_IP=103.142.214.62

# Port web UI manager (default: 8080)
OVPN_PORT=8080

# ── OpenVPN Service ─────────────────────────────────────────
# Nama unit systemd OpenVPN di server ini.
# Contoh: openvpn@server | openvpn-server@server
OVPN_SERVICE=openvpn-server@server

# ── Autentikasi (opsional — lebih baik set di manager.toon) ─
# Kosongkan baris ini agar password dibaca dari manager.toon.
# OVPN_USER=admin
# OVPN_PASS=plaintextpassword   # ← TIDAK disarankan di produksi
